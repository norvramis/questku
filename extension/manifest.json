{
    "name": "Questku",
    "description": "Automatically enroll, complete, and claim Discord quests.",
    "version": "0.0.0",
    "manifest_version": 3,
    "minimum_chrome_version": "116",
    "icons": {
        "16": "assets/icon16.png",
        "48": "assets/icon48.png",
        "128": "assets/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "assets/icon128.png",
        "default_title": "Questku"
    },
    "permissions": [
        "declarativeNetRequest",
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://discord.com/*",
        "*://*.discord.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "declarative_net_request": {
        "rule_resources": [{
            "id": "ua_override",
            "enabled": true,
            "path": "rules.json"
        }]
    }
}
